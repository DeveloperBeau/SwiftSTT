#!/usr/bin/env sh
# Pre-commit hook: lint staged Swift files with swift-format.
#
# Bypass with --no-verify (discouraged). To install, run scripts/install-hooks.sh.

set -e

staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.swift$' || true)
if [ -z "$staged" ]; then
    exit 0
fi

if ! command -v swift >/dev/null 2>&1; then
    echo "swift not on PATH; skipping swift-format lint"
    exit 0
fi

# `swift format lint` exits non-zero on parse errors, but only emits warnings
# for style violations. --strict promotes those warnings to a non-zero exit.
echo "$staged" | tr '\n' '\0' | xargs -0 swift format lint --strict
